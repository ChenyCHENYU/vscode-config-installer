{
  "name": "@agile-team/vscode-config",
  "version": "3.10.1",
  "description": "One-command editor configuration installer (VS Code / Cursor / Windsurf / Kiro) for team standard setup",
  "main": "lib/installer.js",
  "bin": {
    "vscode-config": "./bin/cli.js"
  },
  "files": [
    "bin/",
    "lib/",
    "defaults/",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "vscode",
    "cursor",
    "windsurf",
    "kiro",
    "configuration",
    "setup",
    "development",
    "ide",
    "team",
    "settings",
    "extensions"
  ],
  "author": "CHENY <ycyplus@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ChenyCHENYU/vscode-config-installer.git"
  },
  "homepage": "https://github.com/ChenyCHENYU/vscode-config-installer#readme",
  "bugs": {
    "url": "https://github.com/ChenyCHENYU/vscode-config-installer/issues"
  },
  "engines": {
    "node": ">=16.7.0"
  },
  "dependencies": {
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "commander": "^9.5.0",
    "gradient-string": "^3.0.0",
    "log-symbols": "^4.1.0",
    "ora": "^5.4.1",
    "prompts": "^2.4.2"
  },
  "scripts": {
    "start": "node bin/cli.js",
    "test": "node --test test/*.test.js",
    "sync-defaults": "node scripts/sync-defaults.js",
    "download-extensions": "node scripts/download-extensions.js",
    "prepublishOnly": "node scripts/sync-defaults.js",
    "prepare": "husky",
    "cz": "git-cz",
    "lint": "eslint lib/ bin/ --fix",
    "format": "prettier --write \"lib/\" \"bin/\" \"*.js\""
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@robot-admin/git-standards": "^1.0.3",
    "commitizen": "^4.3.1",
    "cz-customizable": "^7.5.4",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-customizable"
    }
  },
  "lint-staged": {
    "{lib,bin}/**/*.js": [
      "eslint --fix --no-cache",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}